## backend-proxy와 동일한 DB (WikiMd, Document 테이블을 읽기 전용으로 조회)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>

## Qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_SUMMARY_COLLECTION=wiki_summary
QDRANT_CHUNK_COLLECTION=wiki_chunk

## LLM (사내 게이트웨이/프록시 경유, api.openai.com이 아닐 수 있음)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_VERSION=
EMBEDDING_MODEL=aitl-prd-text-embedding-3-small
CHAT_MODEL=gpt-4o

## 검색/랭킹 튜닝값
TOP_K_SUMMARY=5
TOP_K_CHUNK=8
TOP_K_RERANK=5
MIN_SCORE=0.2
CONFIDENCE_THRESHOLD=0.5
MAX_RETRIES=2
